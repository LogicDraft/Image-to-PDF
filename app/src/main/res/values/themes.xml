<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light Theme with Dynamic Color Support -->
    <style name="Theme.ImageToPDF" parent="Base.Theme.ImageToPDF" />

    <style name="Base.Theme.ImageToPDF" parent="Theme.Material3.Light.NoActionBar">
        <!-- Dynamic Colors (Material You) will be applied automatically by the system/library on Android 12+ -->
        
        <!-- Fallback/Default Colors for Android 11 and below (or if Dynamic Colors disabled) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_variant</item>
        <item name="colorOnPrimaryContainer">@color/on_primary</item>
        
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_variant</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary</item>

        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_primary</item>
        <item name="colorTertiaryContainer">@color/tertiary</item>
        <item name="colorOnTertiaryContainer">@color/on_primary</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>
        
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        
        <item name="colorOutline">@color/outline</item>
        
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Theme Variants (Legacy support or Manual Override) -->
    <!-- We keep these but ensure they inherit correctly for manual selection -->
    <style name="Theme.ImageToPDF.Blue" parent="Base.Theme.ImageToPDF">
        <!-- Blue is the default callbacks above -->
    </style>

    <style name="Theme.ImageToPDF.Red" parent="Base.Theme.ImageToPDF">
        <item name="colorPrimary">@color/primary_red</item>
        <item name="colorOnPrimary">@color/on_primary_red</item>
        <item name="colorPrimaryContainer">@color/primary_variant_red</item>
        <item name="colorSecondary">@color/secondary_red</item>
        <item name="colorOnSecondary">@color/on_secondary_red</item>
        <item name="colorSecondaryContainer">@color/secondary_variant_red</item>
    </style>

    <style name="Theme.ImageToPDF.Green" parent="Base.Theme.ImageToPDF">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorOnPrimary">@color/on_primary_green</item>
        <item name="colorPrimaryContainer">@color/primary_variant_green</item>
        <item name="colorSecondary">@color/secondary_green</item>
        <item name="colorOnSecondary">@color/on_secondary_green</item>
        <item name="colorSecondaryContainer">@color/secondary_variant_green</item>
    </style>

    <style name="Theme.ImageToPDF.Orange" parent="Base.Theme.ImageToPDF">
        <item name="colorPrimary">@color/primary_orange</item>
        <item name="colorOnPrimary">@color/on_primary_orange</item>
        <item name="colorPrimaryContainer">@color/primary_variant_orange</item>
        <item name="colorSecondary">@color/secondary_orange</item>
        <item name="colorOnSecondary">@color/on_secondary_orange</item>
        <item name="colorSecondaryContainer">@color/secondary_variant_orange</item>
    </style>

    <style name="Theme.ImageToPDF.Purple" parent="Base.Theme.ImageToPDF">
        <item name="colorPrimary">@color/primary_purple</item>
        <item name="colorOnPrimary">@color/on_primary_purple</item>
        <item name="colorPrimaryContainer">@color/primary_variant_purple</item>
        <item name="colorSecondary">@color/secondary_purple</item>
        <item name="colorOnSecondary">@color/on_secondary_purple</item>
        <item name="colorSecondaryContainer">@color/secondary_variant_purple</item>
    </style>

    <!-- Dynamic Color Theme Overlay for Light Mode (Android 12+) -->
    <style name="ThemeOverlay.ImageToPDF.DynamicColors.Light" parent="">
        <!-- This will be automatically populated by Material You on Android 12+ -->
    </style>

    <!-- Shape Appearances -->
    <style name="ShapeAppearance.ImageToPDF.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.ImageToPDF.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.ImageToPDF.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.ImageToPDF.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.ImageToPDF.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.ImageToPDF.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.ImageToPDF.Button.Tertiary" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.ImageToPDF.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- FAB Style -->
    <style name="Widget.ImageToPDF.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.ImageToPDF.MediumComponent</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.ImageToPDF.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Settings Card Style -->
    <style name="Widget.ImageToPDF.SettingsCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Widget.ImageToPDF.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/on_surface</item>
    </style>

    <!-- Text Appearances -->
    <style name="TextAppearance.ImageToPDF.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.ImageToPDF.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.ImageToPDF.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/on_surface</item>
    </style>
</resources>
